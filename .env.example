# Local Windows 11 development. Do not put real production secrets here.

DATABASE_URL="postgresql://postgres:CHANGE_ME@127.0.0.1:5432/temnaya_kasta?schema=public"
APP_URL="https://temnayakasta120.ru"

# Stable Server Actions key for production rebuilds and restarts.
# Generate a real secret in .env with `npm run env:server-action-key`.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# Public origins for the direct-host launch.
SITE_DOMAIN_1="temnayakasta120.ru"
SITE_DOMAIN_2="temnayakasta120.online"

# Direct-host mode: do not trust spoofable proxy headers by default.
# Set TRUST_PROXY="true" only after placing the app behind a trusted reverse proxy/CDN
# that overwrites X-Forwarded-For/X-Real-IP/CF-Connecting-IP.
TRUST_PROXY="false"

# Enable only when the public site is served exclusively over HTTPS.
ENABLE_HSTS="false"

# Optional but recommended dedicated pepper for verification-code HMACs.
# If empty, the app falls back to NEXT_SERVER_ACTIONS_ENCRYPTION_KEY.
VERIFICATION_CODE_PEPPER=""

# SMTP is optional in local dev, but required for real email verification.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Temnaya Kasta <no-reply@example.com>"

# Optional: send one test email with `npm run smtp:check`.
SMTP_TEST_TO=""

# Legal operator data.
LEGAL_OPERATOR_NAME=""
LEGAL_OPERATOR_EMAIL=""
LEGAL_OPERATOR_ADDRESS=""
LEGAL_RKN_NUMBER=""

# Local/test seed accounts only. The seed script refuses to run unless both values
# are explicitly set in the shell or .env for a deliberate local/test seeding run.
ALLOW_DATABASE_SEED="false"
ALLOW_PRODUCTION_SEED="false"
SEED_PASSWORD=""
