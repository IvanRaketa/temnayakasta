# Vercel + Neon deployment template. Never commit real production secrets.

# Use the pooled Neon connection for the application and the direct connection
# only where the deployment workflow explicitly requires it.
DATABASE_URL="postgresql://USER:PASSWORD@NEON_POOLER_HOST/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@NEON_DIRECT_HOST/DATABASE?sslmode=require"
APP_URL="https://temnayakasta120.online"

# Stable Server Actions key for production rebuilds and restarts.
# Generate a real value separately and store it only in Vercel environment variables.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# Vercel is the trusted production proxy. Do not enable this for an arbitrary proxy.
TRUST_PROXY="true"

# Enable only after all production domains are confirmed to use HTTPS.
ENABLE_HSTS="true"

# Optional but recommended dedicated pepper for verification-code HMACs.
# If empty, the app falls back to NEXT_SERVER_ACTIONS_ENCRYPTION_KEY.
VERIFICATION_CODE_PEPPER=""

# SMTP provider settings. Keep credentials only in Vercel environment variables.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Temnaya Kasta <no-reply@example.com>"

# Optional: send one test email with `npm run smtp:check`.
SMTP_TEST_TO=""

# Legal operator data.
LEGAL_OPERATOR_NAME=""
LEGAL_OPERATOR_EMAIL=""
LEGAL_OPERATOR_ADDRESS=""
LEGAL_RKN_NUMBER=""

# Local/test seed accounts only. Never enable production seed without a deliberate review.
ALLOW_DATABASE_SEED="false"
ALLOW_PRODUCTION_SEED="false"
SEED_PASSWORD=""
