{
  "name": "temnaya-kasta",
  "version": "0.1.0",
  "private": true,
  "description": "Data foundation for Temnaya Kasta.",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:webpack": "next dev --webpack",
    "dev:host": "next dev --webpack -H 0.0.0.0",
    "build": "prisma generate && next build --webpack",
    "start": "next start -H 0.0.0.0 -p 3000",
    "clean": "node scripts/clean.mjs",
    "size": "node scripts/size.mjs",
    "env:server-action-key": "node scripts/ensure-server-action-key.mjs",
    "env:check": "node scripts/check-env.mjs",
    "smtp:check": "node scripts/check-smtp.mjs",
    "security:audit": "npm audit",
    "security:audit:high": "npm audit --audit-level=high",
    "security:tools": "node scripts/security-tools.mjs",
    "security:check": "npm run security:audit && npm run security:tools",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma": "prisma validate && prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "db:seed": "prisma db seed"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.15"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-slot": "1.2.4",
    "@tiptap/extension-character-count": "^3.25.0",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-placeholder": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@types/sanitize-html": "^2.16.1",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "17.4.2",
    "emoji-picker-react": "^4.19.1",
    "lucide-react": "1.17.0",
    "next": "16.2.7",
    "nodemailer": "8.0.10",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanitize-html": "^2.17.4",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.7",
    "prettier": "3.8.3",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3"
  }
}
